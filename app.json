{
  "expo": {
    "name": "TaskFlow",
    "slug": "TaskFlow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "taskflow",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.sksatyam.TaskFlow",
      "googleServicesFile": "./GoogleService-Info.plist",
      "scheme": "com.googleusercontent.apps.502199329090-g80f9bjrq04o5uq9jqn4avdebua9g69d",
      "useFrameworks": "static"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sksatyam.TaskFlow",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#6366F1",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.502199329090-g80f9bjrq04o5uq9jqn4avdebua9g69d"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photos to allow you to select a custom profile picture."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
